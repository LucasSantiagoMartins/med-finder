<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MedFinder - Iniciar Sessão</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link rel="stylesheet" href="/base/css/toast.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      :root {
        --primary: #0d6efd;
        --primary-foreground: #ffffff;
        --background: #f8f9fa;
        --border: #e9ecef;
        --muted: #6c757d;
      }

      body {
        font-family: "Inter", sans-serif;
        background-color: var(--background);
        margin: 0;
        overflow-x: hidden;
      }

      .min-vh-100 {
        min-height: 100vh;
      }

      /* Estilo do Painel de Branding */
      .gradient-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);
        position: relative;
        overflow: hidden;
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.1);
      }

      .logo-box {
        width: 96px;
        height: 96px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      .plus-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 20px;
        height: 20px;
        background: #dc3545;
        border-radius: 50%;
        font-size: 12px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Estilo do Card e Inputs */
      .card-elevated {
        background: white;
        border-radius: 1rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        border: 1px solid var(--border);
      }

      .form-control {
        height: 3rem;
        border-radius: 0.5rem;
        border: 1px solid var(--border);
      }

      #botao-azul {
        background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);
        color: white;
        border: none;
        height: 3rem;
        font-weight: 600;
        transition: all 0.3s ease;
      }

      #botao-azul:hover {
        opacity: 0.9;
        color: white;
        transform: translateY(-1px);
      }

      .password-toggle {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
      }

      /* Divisor "ou entre com" */
      .separator {
        position: relative;
        text-align: center;
        margin: 1.5rem 0;
      }
      .separator::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background-color: var(--border);
        z-index: 1;
      }
      .separator span {
        position: relative;
        background-color: white;
        padding: 0 0.75rem;
        color: var(--muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        z-index: 2;
      }

      /* Botões Sociais */
      .social-btn {
        height: 3rem;
        border-radius: 0.5rem;
        border: 1px solid var(--border);
        background: white;
        font-weight: 600;
        color: var(--muted);
        transition: all 0.2s ease;
      }
      .social-btn:hover {
        background-color: #f8f9fa;
        color: #212529;
        border-color: #ced4da;
      }

      @media (max-width: 991.98px) {
        .branding-side {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="container-fluid p-0">
      <div class="row g-0 min-vh-100">
        <div
          class="col-lg-6 branding-side gradient-hero d-flex flex-column justify-content-center align-items-center text-white p-5"
        >
          <div class="hero-overlay"></div>

          <div class="position-relative z-1 text-center">
            <i
              data-lucide="sparkles"
              class="position-absolute opacity-25"
              style="top: -80px; left: -80px; width: 32px; height: 32px"
            ></i>
            <i
              data-lucide="sparkles"
              class="position-absolute opacity-25"
              style="bottom: -150px; right: -80px; width: 24px; height: 24px"
            ></i>

            <div class="logo-box mx-auto mb-4">
              <div class="position-relative">
                <i data-lucide="heart" style="width: 48px; height: 48px"></i>
                <div class="plus-badge">+</div>
              </div>
            </div>

            <h1 class="display-5 fw-bold mb-3">MedFinder</h1>
            <p class="lead opacity-75 mx-auto" style="max-width: 380px">
              Descubra o poder da gestão de saúde personalizada e acompanhamento
              de medicamentos.
            </p>
          </div>
        </div>

        <div
          class="col-lg-6 d-flex align-items-center justify-content-center p-4"
        >
          <div class="w-100" style="max-width: 420px">
            <div
              class="d-lg-none d-flex align-items-center justify-content-center gap-2 mb-4"
            >
              <div
                class="p-2 gradient-hero rounded-3 d-flex align-items-center justify-content-center"
              >
                <i data-lucide="pill" class="text-white" size="24"></i>
              </div>
              <span class="h3 fw-bold mb-0 text-primary">MedFinder</span>
            </div>

            <div class="card-elevated p-4 p-md-5">
              <div class="text-center mb-4">
                <h2 class="fw-bold h3 mb-1">Iniciar Sessão</h2>
                <p class="text-muted">Bem-vindo de volta!</p>
              </div>

              <form id="loginForm" action="/autenticacao/entrar" method="POST">
                <div class="mb-3">
                  <label for="phone" class="form-label small fw-semibold"
                    >Endereço de E-mail</label
                  >
                  <input
                    type="text"
                    class="form-control"
                    id="email"
                    name="email"
                    placeholder="teste@gmail.com"
                    required
                  />
                </div>
                <div class="mb-3">
                  <label for="password" class="form-label small fw-semibold">
                    Palavra-passe
                  </label>

                  <div class="position-relative">
                    <input
                      type="password"
                      class="form-control pe-5"
                      id="password"
                      name="senha"
                      placeholder="Digite a senha"
                      required
                    />

                    <button type="button" class="password-toggle">
                      <i data-lucide="eye" size="20"></i>
                    </button>
                  </div>
                </div>
                <div
                  class="d-flex justify-content-between align-items-center mb-4"
                >
                  <div class="form-check">
                    <input
                      type="checkbox"
                      class="form-check-input"
                      id="remember"
                    />
                    <label
                      class="form-check-label small text-muted cursor-pointer"
                      for="remember"
                      >Lembrar-me</label
                    >
                  </div>
                  <a
                    href="#"
                    class="small text-primary text-decoration-none fw-medium"
                    >Esqueceu a palavra-passe?</a
                  >
                </div>
                .
                <button type="submit" class="btn w-100" id="botao-azul">
                  Entrar
                </button>
              </form>

              <br />
              <p class="text-center mb-0 small text-muted">
                Não tem conta?
                <a
                  href="/autenticacao/criar-conta"
                  class="text-primary fw-semibold text-decoration-none"
                  >Criar conta</a
                >
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="/geral/manipulador-requisicao.js"></script>
    <script src="/base/js/base.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        lucide.createIcons();

        const toggleButton = document.querySelector(".password-toggle");
        const passwordInput = document.getElementById("password");

        if (toggleButton && passwordInput) {
          toggleButton.addEventListener("click", function () {
            const isPassword = passwordInput.type === "password";

            passwordInput.type = isPassword ? "text" : "password";

            toggleButton.innerHTML = isPassword
              ? '<i data-lucide="eye-off" size="20"></i>'
              : '<i data-lucide="eye" size="20"></i>';

            lucide.createIcons();
          });
        }

        const loginForm = document.getElementById("loginForm");

        if (loginForm) {
          loginForm.addEventListener("submit", function (event) {
            event.preventDefault();
            manipuladorRequisicao(this, true);
          });
        }
      });
    </script>
  </body>
</html>

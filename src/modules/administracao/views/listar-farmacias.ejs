<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestão de Farmácias - MedFinder</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/listar-farmacias.css" rel="stylesheet">
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <link rel="stylesheet" href="/base/css/toast.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

  <div class="dashboard-container">
    <%- include('partials/administracao-sidebar') %>

    <main class="main-content">
      <div class="container-fluid">

        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
          <div>
            <h1 class="h3 fw-bold mb-1">Gestão de Farmácias</h1>
            <p class="text-muted mb-0">Gerir todas as unidades registadas no sistema MedFinder</p>
          </div>
          <a href="/administracao/adicionar-farmacia" class="btn btn-primary d-inline-flex align-items-center gap-2">
            <i data-lucide="plus" size="18"></i> Adicionar Farmácia
          </a>
        </div>

        <div class="card-elevated p-3 mb-4">
          <div class="row g-3">
            <div class="col-sm-8 position-relative">
              <i data-lucide="search" size="18" class="search-icon"></i>
              <input type="text" class="form-control ps-5" placeholder="Pesquisar por nome, NIF ou localização...">
            </div>
            <div class="col-sm-4">
              <select class="form-select">
                <option value="">Todos os estados</option>
                <option value="ativo">Ativo</option>
                <option value="inativo">Inativo</option>
              </select>
            </div>
          </div>
        </div>

        <div class="card-elevated overflow-hidden">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">ID</th>
                  <th>Nome</th>
                  <th class="d-none d-md-table-cell">Localização</th>
                  <th class="d-none d-lg-table-cell">Responsável</th>
                  <th>NIF</th>
                  <th class="text-end pe-4">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% if (farmacias.length > 0) { %>
                <% farmacias.forEach(f => { %>
                <tr>
                  <td class="ps-4 font-monospace text-primary small">#<%= f.id_farmacia %></td>
                  <td class="fw-medium"><%= f.nome_farmacia %></td>
                  <td class="text-muted d-none d-md-table-cell"><%= f.endereco %></td>
                  <td class="text-muted d-none d-lg-table-cell"><%= f.nome_gerente || 'Sem gerente' %></td>
                  <td><span class="badge bg-light text-dark border"><%= f.nif %></span></td>
                  <td class="text-end pe-4">
                    <div class="d-flex justify-content-end gap-2">
                      <button class="table-action-btn" title="Visualizar" onclick="openViewModal('<%= f.nome_farmacia %>', '<%= f.id_farmacia %>', '<%= f.endereco %>', '<%= f.nome_gerente %>', '<%= f.nif %>')">
                        <i data-lucide="eye" size="16"></i>
                      </button>
                      <button class="table-action-btn" title="Editar" onclick="openEditModal('<%= f.nome_farmacia %>', '<%= f.id_farmacia %>', '<%= f.endereco %>', '<%= f.nif %>')">
                        <i data-lucide="pencil" size="16"></i>
                      </button>
                      <button class="table-action-btn delete" title="Remover" onclick="openDeleteModal('<%= f.nome_farmacia %>', '<%= f.id_farmacia %>')">
                        <i data-lucide="trash-2" size="16"></i>
                      </button>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% } else { %>
                <tr>
                  <td colspan="6" class="text-center p-5 text-muted">Nenhuma farmácia encontrada.</td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="mt-3">
          <p class="text-muted small">Total de <strong><%= farmacias.length %></strong> farmácias registadas.</p>
        </div>
      </div>
    </main>
  </div>

  <div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow">
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Editar Farmácia</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="editFarmaciaForm" action="/administracao/editar-farmacia" method="POST">
          <div class="modal-body">
            <input type="hidden" name="id_farmacia" id="edit-id">
            <div class="mb-3">
              <label class="form-label small fw-bold">Nome da Farmácia</label>
              <input type="text" class="form-control" name="nome_farmacia" id="edit-nome">
            </div>
            <div class="mb-3">
              <label class="form-label small fw-bold">NIF</label>
              <input type="text" class="form-control" name="nif" id="edit-nif">
            </div>
            <div class="mb-3">
              <label class="form-label small fw-bold">Endereço</label>
              <textarea class="form-control" name="endereco" id="edit-local" rows="2"></textarea>
            </div>
          </div>
          <div class="modal-footer border-0">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary">Salvar Alterações</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow">
        <div class="modal-header border-0">
          <h5 class="modal-title fw-bold">Detalhes da Farmácia</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body pt-0">
          <div class="row g-3">
            <div class="col-6">
              <label class="text-muted small d-block">ID da Farmácia</label>
              <span id="modal-id" class="font-monospace text-primary"></span>
            </div>
            <div class="col-6">
              <label class="text-muted small d-block">NIF</label>
              <span id="modal-nif" class="fw-medium"></span>
            </div>
            <div class="col-12">
              <label class="text-muted small d-block">Nome</label>
              <span id="modal-nome" class="fw-medium"></span>
            </div>
            <div class="col-12">
              <label class="text-muted small d-block">Localização/Endereço</label>
              <span id="modal-local" class="fw-medium"></span>
            </div>
            <div class="col-12">
              <label class="text-muted small d-block">Gerente Responsável</label>
              <span id="modal-resp" class="fw-medium"></span>
            </div>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Fechar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-body text-center p-4">
          <div class="text-danger mb-3"><i data-lucide="alert-triangle" size="48"></i></div>
          <h5 class="fw-bold">Confirmar Remoção</h5>
          <p class="text-muted small">Deseja realmente remover a farmácia <strong id="delete-nome"></strong>?</p>
          <input type="hidden" id="delete-id">
          <div class="d-flex gap-2 justify-content-center mt-4">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-danger" onclick="confirmDelete()">Remover</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/geral/manipulador-requisicao.js"></script>
  <script src="/base/js/base.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    lucide.createIcons();

    const viewModal = new bootstrap.Modal(document.getElementById('viewModal'));
    const editModal = new bootstrap.Modal(document.getElementById('editModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    let valoresOriginais = {};

    function openViewModal(nome, id, local, resp, nif) {
      document.getElementById('modal-nome').innerText = nome;
      document.getElementById('modal-id').innerText = '#' + id;
      document.getElementById('modal-local').innerText = local;
      document.getElementById('modal-resp').innerText = resp || 'Não atribuído';
      document.getElementById('modal-nif').innerText = nif;
      viewModal.show();
    }

    function openEditModal(nome, id, local, nif) {
      document.getElementById('edit-id').value = id;
      document.getElementById('edit-nome').value = nome;
      document.getElementById('edit-nif').value = nif;
      document.getElementById('edit-local').value = local;

      valoresOriginais = {
        nome_farmacia: nome,
        nif: nif,
        endereco: local
      };
      editModal.show();
    }

    function openDeleteModal(nome, id) {
      document.getElementById('delete-nome').innerText = nome;
      document.getElementById('delete-id').value = id;
      deleteModal.show();
    }

   document.getElementById('editFarmaciaForm').addEventListener('submit', function(e) {
  e.preventDefault();

  const formData = new FormData(this);
  const id = formData.get('id_farmacia'); 
console.log(id);
  let houveMudanca = false;

  for (let [key, value] of formData.entries()) {
    if (key !== 'id_farmacia' && value !== valoresOriginais[key]) {
      houveMudanca = true;
      break;
    }
  }

  if (!houveMudanca) {
    showToast("info", "Nenhuma alteração detectada.");
    return;
  }

  manipuladorRequisicao(this, true, { 
    method: 'PATCH', 
    url: `/administracao/editar-farmacia/${id}`
  });
});

    function confirmDelete() {
      const id = document.getElementById('delete-id').value;
      const url = `/administracao/remover-farmacia/${id}`;

      manipuladorRequisicao(url, false, {
        method: 'DELETE'
      });
    }
  </script>
</body>

</html>
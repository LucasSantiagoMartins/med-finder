<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MedFinder - Encontre Medicamentos</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/index.css" />
   <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <link rel="stylesheet" href="/base/css/toast.css" />
  <script src="https://unpkg.com/lucide@latest"></script>

</head>

<body>
  <header class="bg-white border-bottom sticky-top py-2">
    <div class="container d-flex align-items-center justify-content-between">
      <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
        <div class="p-2 gradient-hero rounded-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px">
          <i data-lucide="pill" class="text-white" size="20"></i>
        </div>
        <span class="fw-bold fs-4 text-primary">MedFinder</span>
      </a>

      <nav class="d-flex align-items-center gap-3">
        <a href="/calendario" class="text-muted text-decoration-none small fw-medium d-none d-md-block">
          <i data-lucide="calendar" size="16" class="me-1"></i>Calendário
        </a>

        <% if (!usuario) { %>
        <a href="/autenticacao/entrar" class="btn btn-outline-primary btn-sm px-3 rounded-pill">Entrar</a>
        <a href="/autenticacao/criar-conta" class="btn btn-primary btn-sm px-3 rounded-pill">Criar Conta</a>
        <% } else { %>
        <div class="dropdown">
          <button class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:40px; height:40px" data-bs-toggle="dropdown">
            <%= usuario.nome.split(" ").map(n => n[0]).join("").substring(0,2).toUpperCase() %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
            <li class="dropdown-item-text small text-muted">
              <strong><%= usuario.nome %></strong><br /><%= usuario.tipo_usuario %>
            </li>
            <li>
              <hr class="dropdown-divider">
            </li>
            <li><a class="dropdown-item" href="/farmacia/painel">Painel da fármacia</a></li>
            <li><a class="dropdown-item text-danger" href="/autenticacao/logout">Terminar Sessão</a></li>
          </ul>
        </div>
        <% } %>
      </nav>
    </div>
  </header>

  <main id="main-wrapper">
    <section id="hero-section" class="py-5 mt-1">
      <div class="container text-center">
        <div id="hero-content" class="transition-element">
          <h1 class="display-4 fw-bold mb-3">Procure medicamentos em <br /><span class="text-primary">farmácias locais</span></h1>
          <p class="text-secondary mb-5 mx-auto" style="max-width: 600px">Pesquise medicamentos e encontre as farmácias mais próximas com stock disponível. Simples, rápido e confiável.</p>
        </div>

        <div class="input-search-container mb-5" id="search-box-wrapper">
          <i data-lucide="search" class="position-absolute text-muted" style="left: 1.5rem; top: 50%; transform: translateY(-50%)"></i>
          <input type="text" id="input-pesquisa" class="form-control input-search" placeholder="Qual medicamento procura?" />
          <button id="btn-pesquisar-acao" class="btn btn-primary btn-search fw-bold">Pesquisar</button>
        </div>

        <div id="recipe-card" class="card-interactive max-w-2xl mx-auto p-4 d-flex align-items-center gap-4 text-start transition-element" style="max-width: 700px; margin: 0 auto" data-bs-toggle="modal" data-bs-target="#uploadModal">
          <div class="p-3 gradient-hero rounded-4 text-white">
            <i data-lucide="file-text" size="32"></i>
          </div>
          <div class="flex-grow-1">
            <h3 class="h5 fw-bold mb-1">Enviar Receita Médica</h3>
            <p class="text-muted small mb-0">Envie uma foto da sua receita para uma busca automática.</p>
          </div>
          <i data-lucide="chevron-right" class="text-muted"></i>
        </div>
      </div>
    </section>

    <section id="search-results-container" class="py-2" style="display: none; opacity: 0; transition: opacity 0.3s ease;">
      <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="h5 fw-bold mb-0" id="result-title">Resultados da busca</h2>
          <button class="btn btn-sm btn-link text-decoration-none text-muted" onclick="voltarAoInicio()">
            <i data-lucide="x" size="14"></i> Limpar pesquisa
          </button>
        </div>
        <div id="lista-medicamentos-grid" class="row g-4"></div>
      </div>
    </section>

    <section id="features-section" class="py-5">
      <div class="container">
        <div class="row g-4">
          <div class="col-md-4">
            <div class="card-elevated p-4 text-center h-100">
              <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mb-3"><i data-lucide="zap" class="text-primary"></i></div>
              <h5 class="fw-bold">Pesquisa Real-time</h5>
              <p class="text-muted small mb-0">Stock atualizado diretamente pelas farmácias parceiras.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card-elevated p-4 text-center h-100">
              <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mb-3"><i data-lucide="shield-check" class="text-primary"></i></div>
              <h5 class="fw-bold">Segurança Total</h5>
              <p class="text-muted small mb-0">Seus dados e receitas são tratados com sigilo absoluto.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card-elevated p-4 text-center h-100">
              <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mb-3"><i data-lucide="map" class="text-primary"></i></div>
              <h5 class="fw-bold">Geolocalização</h5>
              <p class="text-muted small mb-0">Visualize no mapa a farmácia mais próxima de você.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="py-5 border-top bg-white mt-5">
    <div class="container text-center text-muted small">© 2026 MedFinder. Todos os direitos reservados.</div>
  </footer>

  <div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 rounded-4 shadow">
        <div class="modal-header border-0 pb-0">
          <div>
            <h5 class="modal-title fw-bold">Enviar Receita Médica</h5>
            <p class="text-muted small mb-0">Anexe até 3 imagens da sua receita.</p>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <input type="file" id="input-file-oculto" accept="image/*" multiple style="display: none;">

          <button class="upload-area mb-3" id="btnUpload">
            <i data-lucide="image" class="text-muted mb-2" size="32"></i>
            <span class="small text-muted" id="uploadText">Clique para selecionar</span>
          </button>

          <div id="fileList"></div>

          <div class="d-flex gap-2 mt-4">
            <button class="btn btn-light w-100 fw-bold rounded-pill" data-bs-dismiss="modal">Cancelar</button>
            <button class="btn btn-primary w-100 fw-bold rounded-pill" id="btnConfirm" disabled>
              <span id="textConfirm">Confirmar</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/geral/index.js"></script>
  <script src="/base/js/base.js"></script>
  <script src="/geral/manipulador-requisicao.js"></script>
</body>

</html>
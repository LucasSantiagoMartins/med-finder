<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= titulo %> - MedFinder</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="/css/atualizar-estoque.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link rel="stylesheet" href="/base/css/toast.css" />
  </head>
  <body>
    <div class="d-flex">
      <%- include('partials/farmacia-sidebar') %>

      <main class="main-content">
        <div class="container" style="max-width: 800px">
          <div class="mb-4">
            <h1 class="h3 fw-bold mb-1">Atualizar Stock via Excel/CSV</h1>
            <p class="text-muted">
              Importe a lista de medicamentos da sua farmácia rapidamente.
            </p>
          </div>

          <div class="card-elevated p-4 mb-4">
            <form
              id="medicamentoForm"
              action="/farmacia/atualizar-estoque"
              method="POST"
              enctype="multipart/form-data"
            >
              <div id="dropZone" class="upload-area">
                <input
                  type="file"
                  id="fileInput"
                  name="planilha"
                  class="d-none"
                  accept=".csv, .xlsx, .xls"
                />

                <div id="stateInitial">
                  <div class="icon-box gradient-hero">
                    <i data-lucide="upload" size="32"></i>
                  </div>
                  <h3 class="h5 fw-bold mb-2">Arraste o ficheiro aqui</h3>
                  <p class="text-muted mb-4 small">
                    ou clique para selecionar do seu computador
                  </p>
                  <button
                    type="button"
                    class="btn btn-primary px-4 py-2 fw-semibold"
                    onclick="document.getElementById('fileInput').click()"
                  >
                    <i data-lucide="file-spreadsheet" size="18" class="me-2"></i
                    >Selecionar Ficheiro
                  </button>
                  <p class="text-muted mt-4" style="font-size: 0.7rem">
                    Formatos aceites: .csv, .xlsx • Tamanho máximo: 10MB
                  </p>
                </div>

                <div id="stateUploading" class="d-none">
                  <div id="iconStatus" class="icon-box bg-light">
                    <i
                      data-lucide="file-spreadsheet"
                      size="32"
                      class="text-primary"
                    ></i>
                  </div>
                  <div class="mb-3">
                    <p id="fileName" class="fw-bold mb-1">
                      nome_do_arquivo.csv
                    </p>
                    <p id="uploadStatusText" class="small text-muted">
                      A processar ficheiro...
                    </p>
                  </div>
                  <div class="progress mb-4 mx-auto" style="max-width: 300px">
                    <div
                      id="progressBar"
                      class="progress-bar progress-bar-striped progress-bar-animated"
                      role="progressbar"
                      style="width: 0%"
                    ></div>
                  </div>
                </div>
              </div>
            </form>
          </div>

          <div class="card-elevated p-4 mb-4">
            <h3 class="h6 fw-bold mb-3 d-flex align-items-center">
              <i data-lucide="info" size="18" class="me-2 text-primary"></i
              >Formato do Ficheiro
            </h3>
            <div class="table-responsive">
              <table class="table table-instructions mb-3">
                <thead>
                  <tr>
                    <th>Coluna</th>
                    <th>Tipo</th>
                    <th>Exemplo</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>nome</td>
                    <td>Texto</td>
                    <td>Paracetamol 500mg</td>
                  </tr>
                  <tr>
                    <td>dosagem</td>
                    <td>Texto</td>
                    <td>500mg</td>
                  </tr>
                  <tr>
                    <td>quantidade</td>
                    <td>Número</td>
                    <td>150</td>
                  </tr>
                  <tr>
                    <td>preco</td>
                    <td>Número</td>
                    <td>2500</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <button class="btn btn-light btn-sm text-primary fw-bold">
              <i data-lucide="download" size="14" class="me-2"></i>Descarregar
              Template
            </button>
          </div>
        </div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/geral/manipulador-requisicao.js"></script>
    <script src="/base/js/base.js"></script>

    <script>
      const dropZone = document.getElementById("dropZone");
      const fileInput = document.getElementById("fileInput");
      const medicamentoForm = document.getElementById("medicamentoForm");
      const stateInitial = document.getElementById("stateInitial");
      const stateUploading = document.getElementById("stateUploading");
      const progressBar = document.getElementById("progressBar");
      const uploadStatusText = document.getElementById("uploadStatusText");

      ["dragenter", "dragover"].forEach((name) => {
        dropZone.addEventListener(name, (e) => {
          e.preventDefault();
          dropZone.classList.add("dragging");
        });
      });

      ["dragleave", "drop"].forEach((name) => {
        dropZone.addEventListener(name, (e) => {
          e.preventDefault();
          dropZone.classList.remove("dragging");
        });
      });

      dropZone.addEventListener("drop", (e) => {
        const file = e.dataTransfer.files[0];
        if (file) {
          fileInput.files = e.dataTransfer.files;
          iniciarEnvio(file.name);
        }
      });

      fileInput.addEventListener("change", (e) => {
        if (e.target.files.length > 0) {
          iniciarEnvio(e.target.files[0].name);
        }
      });

      function iniciarEnvio(name) {
        stateInitial.classList.add("d-none");
        stateUploading.classList.remove("d-none");
        document.getElementById("fileName").innerText = name;
        uploadStatusText.innerText = "A processar ficheiro...";
        uploadStatusText.className = "small text-muted";

        let progress = 0;
        const interval = setInterval(() => {
          progress += 25;
          progressBar.style.width = progress + "%";

          if (progress >= 100) {
            clearInterval(interval);
            enviarFormulario();
          }
        }, 100);
      }

      async function enviarFormulario() {
        try {
          const sucesso = await manipuladorRequisicao(medicamentoForm, true);

          if (!sucesso) {
            resetarInterfaceComAtraso();
          }
        } catch (error) {
          resetarInterfaceComAtraso();
        }
      }

      function resetarInterfaceComAtraso() {
        stateInitial.classList.remove("d-none");
        stateUploading.classList.add("d-none");
        progressBar.style.width = "0%";
        fileInput.value = "";
      }

      document.addEventListener("DOMContentLoaded", () => {
        lucide.createIcons();
      });
    </script>
  </body>
</html>
